Documents/GitHub/mmd-flowchart/src/canvas/Canvas.tsx", "source_location": "L170"}, {"caller_nid": "canvas_canvas_canvas", "callee": "useCallback", "is_member_call": false, "source_file": "/Users/jelle/Documents/GitHub/mmd-flowchart/src/canvas/Canvas.tsx", "source_location": "L177"}, {"caller_nid": "canvas_canvas_canvas", "callee": "useCallback", "is_member_call": false, "source_file": "/Users/jelle/Documents/GitHub/mmd-flowchart/src/canvas/Canvas.tsx", "source_location": "L184"}, {"caller_nid": "canvas_canvas_canvas", "callee": "useCallback", "is_member_call": false, "source_file": "/Users/jelle/Documents/GitHub/mmd-flowchart/src/canvas/Canvas.tsx", "source_location": "L186"}, {"caller_nid": "canvas_canvas_canvas", "callee": "useCallback", "is_member_call": false, "source_file": "/Users/jelle/Documents/GitHub/mmd-flowchart/src/canvas/Canvas.tsx", "source_location": "L198"}, {"caller_nid": "canvas_canvas_canvas", "callee": "useEffect", "is_member_call": false, "source_file": "/Users/jelle/Documents/GitHub/mmd-flowchart/src/canvas/Canvas.tsx", "source_location": "L223"}, {"caller_nid": "canvas_canvas_canvas", "callee": "useCallback", "is_member_call": false, "source_file": "/Users/jelle/Documents/GitHub/mmd-flowchart/src/canvas/Canvas.tsx", "source_location": "L249"}, {"caller_nid": "canvas_canvas_canvas", "callee": "useCallback", "is_member_call": false, "source_file": "/Users/jelle/Documents/GitHub/mmd-flowchart/src/canvas/Canvas.tsx", "source_location": "L256"}, {"caller_nid": "canvas_canvas_canvas", "callee": "(() => {\n          const start = diagram.blocks[\"S\"];\n          if (!start) return null;\n          // Eigen SVG-overlay i.p.v. xyflow's <Background> zodat we exact\n          // controle hebben over de positie van de lijnen. De portal\n          // erft de viewport-transform, dus we kunnen world-coordinaten\n          // gebruiken; non-scaling-stroke houdt lijndikte constant bij\n          // in/uitzoomen.\n          const sx = start.position.x + start.width / 2;\n          const sy = start.position.y + start.height / 2;\n          const RANGE = 60; // cellen in elke richting \u2014 ruim voor 200 blokken\n          const minX = sx - (RANGE + 0.5) * MACRO_PITCH_X;\n          const maxX = sx + (RANGE + 0.5) * MACRO_PITCH_X;\n          const minY = sy - (RANGE + 0.5) * MACRO_PITCH_Y;\n          const maxY = sy + (RANGE + 0.5) * MACRO_PITCH_Y;\n          const verticalXs: number[] = [];\n          const horizontalYs: number[] = [];\n          // Cel-grenzen liggen op Start.center \u00b1 (k \u2212 \u00bd) \u00b7 pitch.\n          for (let k = -RANGE; k <= RANGE + 1; k++) {\n            verticalXs.push(sx + (k - 0.5) * MACRO_PITCH_X);\n            horizontalYs.push(sy + (k - 0.5) * MACRO_PITCH_Y);\n          }\n          return (\n            <ViewportPortal>\n              <svg\n                style={{\n                  position: \"absolute\",\n                  left: minX,\n                  top: minY,\n                  width: maxX - minX,\n                  height: maxY - minY,\n                  pointerEvents: \"none\",\n                  zIndex: -1,\n                }}\n              >\n                {verticalXs.map((x) => (\n                  <line\n                    key={`v${x}`}\n                    x1={x - minX}\n                    x2={x - minX}\n                    y1={0}\n                    y2={maxY - minY}\n                    stroke=\"var(--claude-border-hover)\"\n                    strokeWidth={1}\n                    strokeDasharray=\"2 4\"\n                    vectorEffect=\"non-scaling-stroke\"\n                  />\n                ))}\n                {horizontalYs.map((y) => (\n                  <line\n                    key={`h${y}`}\n                    x1={0}\n                    x2={maxX - minX}\n                    y1={y - minY}\n                    y2={y - minY}\n                    stroke=\"var(--claude-border-hover)\"\n                    strokeWidth={1}\n                    strokeDasharray=\"2 4\"\n                    vectorEffect=\"non-scaling-stroke\"\n                  />\n                ))}\n              </svg>\n            </ViewportPortal>\n          );\n        })", "is_member_call": false, "source_file": "/Users/jelle/Documents/GitHub/mmd-flowchart/src/canvas/Canvas.tsx", "source_location": "L315"}]}